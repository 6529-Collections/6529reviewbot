{
  "openapi": "3.1.0",
  "info": {
    "title": "6529reviewbot Usage API",
    "version": "0.1.0",
    "description": "Read-side API contract for public 6529.io transparency pages and private 6529.io admin dashboards."
  },
  "servers": [
    {
      "url": "https://{botHost}",
      "variables": {
        "botHost": {
          "default": "reviewbot.example.com"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Public"
    },
    {
      "name": "Admin"
    }
  ],
  "paths": {
    "/api/public/usage/summary": {
      "get": {
        "tags": ["Public"],
        "summary": "Public aggregate usage summary",
        "parameters": [
          {
            "$ref": "#/components/parameters/Days"
          }
        ],
        "responses": {
          "200": {
            "description": "Public usage summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageSummary"
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/admin/usage/summary": {
      "get": {
        "tags": ["Admin"],
        "summary": "Admin aggregate usage summary",
        "security": [
          {
            "adminHmac": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Days"
          }
        ],
        "responses": {
          "200": {
            "description": "Admin usage summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageSummary"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/admin/budget/policies": {
      "get": {
        "tags": ["Admin"],
        "summary": "Enabled budget policies",
        "security": [
          {
            "adminHmac": []
          }
        ],
        "responses": {
          "200": {
            "description": "Budget policies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BudgetPoliciesResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/admin/jobs/recent": {
      "get": {
        "tags": ["Admin"],
        "summary": "Recent job lifecycle events",
        "security": [
          {
            "adminHmac": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 50
            },
            "description": "Maximum rows to return, capped by REVIEWBOT_USAGE_API_MAX_ITEMS."
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Optional exact job status filter, for example dispatch_failed."
          }
        ],
        "responses": {
          "200": {
            "description": "Recent job events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobEventsResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/api/admin/status": {
      "get": {
        "tags": ["Admin"],
        "summary": "Runtime preflight status",
        "security": [
          {
            "adminHmac": []
          }
        ],
        "parameters": [
          {
            "name": "profile",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["server", "worker"],
              "default": "server"
            }
          },
          {
            "name": "strict",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Runtime status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeStatusResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "adminHmac": {
        "type": "apiKey",
        "in": "header",
        "name": "x-6529-admin-signature",
        "description": "Short-lived 6529.io admin HMAC assertion. Requests also include x-6529-admin-user, x-6529-admin-roles, and x-6529-admin-expires-at. Actor values cannot contain control characters, and roles must use letters, digits, underscore, dot, colon, or hyphen."
      }
    },
    "parameters": {
      "Days": {
        "name": "days",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "description": "Lookback window, capped by REVIEWBOT_USAGE_API_MAX_DAYS."
      }
    },
    "responses": {
      "Forbidden": {
        "description": "Admin authorization failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unavailable": {
        "description": "Configured data loader is unavailable",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["ok", "error"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "UsageSummary": {
        "type": "object",
        "required": ["ok", "visibility", "kind", "range", "totals", "byDay", "byRepo", "byProviderModel", "byReviewKind"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "visibility": {
            "type": "string",
            "enum": ["public", "admin"]
          },
          "kind": {
            "type": "string",
            "const": "usage_summary"
          },
          "range": {
            "$ref": "#/components/schemas/UsageRange"
          },
          "totals": {
            "$ref": "#/components/schemas/UsageTotals"
          },
          "byDay": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          },
          "byRepo": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          },
          "byProviderModel": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          },
          "byReviewKind": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          },
          "byRequestor": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          },
          "byPr": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageGroup"
            }
          }
        },
        "additionalProperties": false
      },
      "UsageRange": {
        "type": "object",
        "properties": {
          "days": {
            "type": "integer"
          },
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "UsageTotals": {
        "type": "object",
        "required": ["reviewRuns", "costUsd", "totalTokens", "budgetSkippedRuns"],
        "properties": {
          "reviewRuns": {
            "type": "integer"
          },
          "costUsd": {
            "type": "number"
          },
          "totalTokens": {
            "type": "integer"
          },
          "budgetSkippedRuns": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "UsageGroup": {
        "type": "object",
        "required": ["key", "reviewRuns", "costUsd", "totalTokens", "budgetSkippedRuns"],
        "properties": {
          "key": {
            "type": "string"
          },
          "reviewRuns": {
            "type": "integer"
          },
          "costUsd": {
            "type": "number"
          },
          "totalTokens": {
            "type": "integer"
          },
          "budgetSkippedRuns": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "BudgetPoliciesResponse": {
        "type": "object",
        "required": ["ok", "visibility", "kind", "policies"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "visibility": {
            "type": "string",
            "const": "admin"
          },
          "kind": {
            "type": "string",
            "const": "budget_policies"
          },
          "policies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BudgetPolicy"
            }
          }
        },
        "additionalProperties": false
      },
      "BudgetPolicy": {
        "type": "object",
        "required": ["scopeType", "scopeValue", "dailyBudgetUsd", "weeklyBudgetUsd", "monthlyBudgetUsd", "enabled"],
        "properties": {
          "scopeType": {
            "type": "string"
          },
          "scopeValue": {
            "type": "string"
          },
          "dailyBudgetUsd": {
            "type": ["number", "null"]
          },
          "weeklyBudgetUsd": {
            "type": ["number", "null"]
          },
          "monthlyBudgetUsd": {
            "type": ["number", "null"]
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "JobEventsResponse": {
        "type": "object",
        "required": ["ok", "visibility", "kind", "limit", "status", "events"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "visibility": {
            "type": "string",
            "const": "admin"
          },
          "kind": {
            "type": "string",
            "const": "job_events"
          },
          "limit": {
            "type": "integer"
          },
          "status": {
            "type": ["string", "null"]
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobEvent"
            }
          }
        },
        "additionalProperties": false
      },
      "JobEvent": {
        "type": "object",
        "required": ["createdAt", "jobId", "status", "stage", "repoFullName", "reviewKind", "provider", "model"],
        "properties": {
          "eventId": {
            "type": ["number", "null"]
          },
          "createdAt": {
            "type": "string"
          },
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "repoFullName": {
            "type": "string"
          },
          "prNumber": {
            "type": ["number", "null"]
          },
          "prAuthor": {
            "type": "string"
          },
          "prHeadSha": {
            "type": "string"
          },
          "deliveryId": {
            "type": "string"
          },
          "requestor": {
            "type": "string"
          },
          "reviewKind": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "lane": {
            "type": "string"
          },
          "adapter": {
            "type": "string"
          },
          "accepted": {
            "type": ["boolean", "null"]
          },
          "reason": {
            "type": "string"
          },
          "exitCode": {
            "type": ["number", "null"]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "RuntimeStatusResponse": {
        "type": "object",
        "required": ["ok", "visibility", "kind", "generatedAt", "profile", "strict", "preflight"],
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "visibility": {
            "type": "string",
            "const": "admin"
          },
          "kind": {
            "type": "string",
            "const": "runtime_status"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "profile": {
            "type": "string",
            "enum": ["server", "worker"]
          },
          "strict": {
            "type": "boolean"
          },
          "preflight": {
            "type": ["object", "null"],
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}

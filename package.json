{
  "name": "@6529/6529reviewbot",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-neutral AI pull request review bot for 6529 repositories.",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/6529-Collections/6529reviewbot.git"
  },
  "bugs": {
    "url": "https://github.com/6529-Collections/6529reviewbot/issues"
  },
  "homepage": "https://github.com/6529-Collections/6529reviewbot#readme",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "node scripts/check.cjs",
    "test": "node scripts/smoke-test.cjs",
    "start": "node bin/server.cjs",
    "review:general": "node bin/general-pr-review.cjs",
    "review:followup": "node bin/followup-commit-review.cjs",
    "review:wcag": "node bin/wcag-aa-analysis.cjs",
    "review:i18n": "node bin/i18n-analysis.cjs",
    "review:security": "node bin/security-analysis.cjs",
    "worker:job": "node bin/run-review-job.cjs",
    "alerts:spend": "node bin/run-spend-alert-check.cjs",
    "ledger:schema": "node bin/apply-ledger-schema.cjs",
    "budget-policies": "node bin/apply-budget-policies.cjs",
    "model-prices": "node bin/apply-model-prices.cjs",
    "preflight": "node bin/preflight.cjs",
    "support:bundle": "node bin/support-bundle.cjs",
    "v0:gates": "node bin/v0-gates.cjs",
    "webhook:replay": "node bin/replay-webhook.cjs",
    "github-app:manifest": "node bin/render-github-app-manifest.cjs",
    "github-app:convert": "node bin/convert-github-app-manifest.cjs",
    "github-app:token": "node bin/github-app-installation-token.cjs",
    "check:workflow-actions": "node scripts/check-workflow-actions.cjs",
    "validate:api-contract": "node bin/validate-usage-api-openapi.cjs",
    "validate:model-catalog": "node bin/validate-model-catalog.cjs",
    "validate:repo-config": "node bin/validate-repository-config.cjs",
    "release:check": "node scripts/release-check.cjs"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}

# 6529.io server-side environment for 6529bot dashboards.
#
# Copy these names into the private 6529.io deployment secret/config system.
# Do not commit live hosts, wallet allowlists, auth endpoints, or secrets.

# Shared public/private bot API origin.
REVIEWBOT_USAGE_API_BASE_URL=https://reviewbot.example.com

# Public Open Data route.
REVIEWBOT_USAGE_API_PUBLIC_SUMMARY_PATH=/api/public/usage/summary

# Private 6529bot admin route.
REVIEWBOT_USAGE_ADMIN_ALLOWED_WALLETS=
REVIEWBOT_USAGE_ADMIN_AUTH_CHECK_URL=
REVIEWBOT_USAGE_API_ADMIN_HMAC_SECRET=
REVIEWBOT_USAGE_API_ADMIN_ROLES=reviewbot-admin
REVIEWBOT_USAGE_API_ADMIN_TTL_SECONDS=300
REVIEWBOT_USAGE_API_ADMIN_SUMMARY_PATH=/api/admin/usage/summary
REVIEWBOT_USAGE_API_ADMIN_BUDGET_STATUS_PATH=/api/admin/budget/status
REVIEWBOT_USAGE_API_ADMIN_MODEL_PRICE_STATUS_PATH=/api/admin/model-prices/status
REVIEWBOT_USAGE_API_ADMIN_ALERT_STATUS_PATH=/api/admin/alerts/status
REVIEWBOT_USAGE_API_ADMIN_STATUS_PATH=/api/admin/status?profile=server&strict=false
REVIEWBOT_USAGE_API_ADMIN_JOB_EVENTS_PATH=/api/admin/jobs/recent?status=dispatch_failed&limit=10
REVIEWBOT_USAGE_API_ADMIN_RUN_CLAIMS_PATH=/api/admin/run-claims/recent?active=1&staleMinutes=120&limit=10
